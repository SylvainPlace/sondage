{
  "name": "sondage-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "oxlint src",
    "lint:fix": "oxlint --fix src",
    "typecheck": "tsc --noEmit",
    "format": "oxfmt --write \"src/**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "oxfmt --check \"src/**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:fix": "oxfmt --write \"src/**/*.{ts,tsx,js,jsx,json,md}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run lint && npm run typecheck && npm test && npm run format:check",
    "check:fix": "npm run lint:fix && npm run format:fix",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "build:cloudflare": "opennextjs-cloudflare build",
    "deploy:cloudflare": "opennextjs-cloudflare deploy",
    "prepare": "husky",
    "cf:types": "wrangler types --env-interface CloudflareEnv"
  },
  "dependencies": {
    "chart.js": "^4.4.1",
    "geojson": "^0.5.0",
    "jose": "^6.2.2",
    "knip": "^6.2.0",
    "leaflet": "^1.9.4",
    "next": "^16.2.1",
    "react": "^19.2.4",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260401.1",
    "@opennextjs/cloudflare": "^1.18.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/leaflet": "^1.9.8",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "esbuild": "^0.27.4",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "typescript": "^6",
    "vitest": "^4.1.2",
    "wrangler": "^4.79.0"
  }
}
